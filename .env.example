# zkSentinel Environment Configuration
# Copy this file to .env.local and fill in your actual values

# X Layer Network Configuration
NEXT_PUBLIC_XLAYER_RPC_URL=https://rpc.xlayer.tech
NEXT_PUBLIC_XLAYER_CHAIN_ID=196
NEXT_PUBLIC_XLAYER_EXPLORER_URL=https://www.okx.com/explorer/xlayer

# OKX Onchain OS Plugin Configuration
# Get credentials from: https://www.okx.com/web3/build/docs/devportal/introduction
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
