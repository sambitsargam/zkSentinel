# zkSentinel Environment Configuration
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. Fill in all required values below
# 3. DO NOT commit .env.local to git (it's in .gitignore)
# 4. Restart the application after making changes

# ============================================================================
# X Layer Network Configuration (REQUIRED)
# ============================================================================
# X Layer is the zkEVM blockchain where all transactions are executed
# These values should not be changed unless using a different network

NEXT_PUBLIC_XLAYER_RPC_URL=https://rpc.xlayer.tech
NEXT_PUBLIC_XLAYER_CHAIN_ID=196
NEXT_PUBLIC_XLAYER_EXPLORER_URL=https://www.okx.com/explorer/xlayer

# ============================================================================
# OKX Onchain OS Plugin Configuration (REQUIRED)
# ============================================================================
# The OKX Onchain OS plugin serves as the core execution layer for autonomous
# onchain actions. Get your credentials from:
# https://www.okx.com/web3/build/docs/devportal/introduction
#
# Steps to get credentials:
# 1. Create an OKX account
# 2. Navigate to API Management
# 3. Create a new API key with appropriate permissions
# 4. Save the API Key, Secret Key, and Passphrase

OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# ============================================================================
# OpenAI API Configuration (REQUIRED)
# ============================================================================
# OpenAI API is used for AI-powered risk analysis and action recommendations
# Get your API key from: https://platform.openai.com/api-keys
#
# Steps to get API key:
# 1. Create an OpenAI account
# 2. Navigate to API Keys section
# 3. Create a new secret key
# 4. Copy the key (starts with "sk-")

OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# Application Configuration (OPTIONAL)
# ============================================================================
# These values have sensible defaults for local development

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
